# Ignore all .exe files
*.exe

# Ignore compiled C/C++ objects and binaries
*.o
*.out
*.obj
a.out
*.bin

# Ignore generated executable files without extensions
/kruskal
/9th_selectionSort
/10th_quickSort
/11th_mergeSort
/dijkstras
/floyds
/knapsackGreedy
/knapsackZeroOne
/SumOfSubset
/warshalls
/tempCodeRunnerFile

# Ignore any other compiled/generated files in this folder
*
!*.c
!*.h
!README*
!.gitignore

# Ignore macOS debug symbol directories
*.dSYM/
*.dSYM

# Ignore editor and system temporary files
*.swp
*~
.DS_Store
